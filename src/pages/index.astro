---
import Layout from '../layouts/Layout.astro';

const serviceAreas = [
  { id: 'bookkeeping', name: 'Bookkeeping & Financial', blurb: 'AP/AR, reconciliation, BAS lodgement — clean books, always current.' },
  { id: 'admin', name: 'Administration & Executive Support', blurb: 'Inbox, calendar, documents, and the paperwork that used to eat your evenings.' },
  { id: 'hr-payroll', name: 'HR & Payroll', blurb: 'Payroll, STP, super, Fair Work compliance — handled accurately and on time.' },
  { id: 'operations', name: 'Operations & Procurement', blurb: 'Purchase orders, supplier management, inventory — kept moving.' },
  { id: 'marketing', name: 'Marketing', blurb: 'Social, content, campaigns — a consistent presence without an in-house team.' },
  { id: 'customer-service', name: 'Customer Service', blurb: 'Tickets, live chat, phone overflow — fast, on-brand, always covered.' },
  { id: 'systems', name: 'Systems & Project Management', blurb: 'Migrations, new tools, complex initiatives — led from scoping to go-live.' },
];

const tickerLines = [
  'Invoice #4521 reconciled — Xero',
  'STP lodgement filed on time',
  '3 support tickets closed — 12 min avg',
  'Supplier PO #118 approved',
  'Payroll run complete — 14 staff',
  'BAS draft ready for review',
  'Onboarding checklist sent — new hire',
  'Weekly cashflow forecast updated',
];

const differentiators = [
  { title: 'AI backbone, human judgement', body: 'Automation handles the repetitive. Our team handles the nuanced calls that actually need a person.' },
  { title: 'Solution-first, not headcount-first', body: "You're buying an outcome, not another line on the payroll." },
  { title: 'Built for Australian compliance', body: 'Fair Work, STP, BAS, GST — the rules are already baked into how we work.' },
  { title: 'No lock-in to start', body: 'Cancel your entry-tier service anytime with 30 days notice. No long contracts to test the waters.' },
];
---

<Layout title="Your AI-powered 2IC for Australian small business">
  <!-- HERO -->
  <section class="relative overflow-hidden">
    <div class="mx-auto max-w-6xl px-6 pt-16 pb-20 md:pt-24 md:pb-28 grid md:grid-cols-[1.15fr_0.85fr] gap-14 items-center">
      <div>
        <span class="inline-flex items-center gap-2 rounded-full bg-ink/5 border border-ink/10 px-3.5 py-1.5 text-xs font-semibold uppercase tracking-wide text-ink/70">
          Built for Australian SMEs
        </span>
        <h1 class="mt-6 font-[General_Sans] font-bold text-[2.6rem] leading-[1.08] tracking-tight md:text-[3.4rem]">
          Run your business.<br />
          Let your <span class="text-teal-dark">2IC</span> run the rest.
        </h1>
        <p class="mt-6 text-lg text-slate leading-relaxed max-w-lg">
          Hyture is an AI-powered second-in-command for small business —
          bookkeeping, admin, HR, ops, marketing and customer service,
          handled by automation and reviewed by real people, every time.
        </p>
        <div class="mt-9 flex flex-wrap items-center gap-4">
          <a href="/contact" class="inline-flex items-center rounded-full bg-amber text-ink px-7 py-3.5 font-semibold hover:brightness-95 transition">
            Book a scoping call
          </a>
          <a href="/services" class="inline-flex items-center gap-1.5 text-ink font-semibold hover:text-teal-dark transition-colors">
            See all service areas
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
          </a>
        </div>
      </div>

      <!-- Signature element: a quiet "operations console" showing the AI+human workflow in motion -->
      <div class="relative">
        <div class="rounded-2xl bg-ink text-sand shadow-xl overflow-hidden">
          <div class="flex items-center gap-2 px-5 py-3.5 border-b border-sand/10">
            <span class="w-2.5 h-2.5 rounded-full bg-teal"></span>
            <span class="text-xs font-semibold tracking-wide text-sand/70">2IC operations feed — live</span>
          </div>
          <div class="h-[280px] overflow-hidden relative px-5 py-4">
            <div class="ticker-track">
              {[...tickerLines, ...tickerLines].map((line) => (
                <div class="flex items-center gap-3 py-2.5 border-b border-sand/8 text-[0.92rem]">
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none" class="shrink-0">
                    <circle cx="7" cy="7" r="6.3" stroke="#00C2B8" stroke-width="1.3"/>
                    <path d="M4.2 7.2L6 9L9.8 5" stroke="#00C2B8" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span class="text-sand/85">{line}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="px-5 py-3.5 border-t border-sand/10 text-xs text-sand/55">
            Every line reviewed by a named human before it reaches you.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPLIANCE TRUST BAR -->
  <section class="border-y border-ink/10 bg-sand-dark/50">
    <div class="mx-auto max-w-6xl px-6 py-6 flex flex-wrap items-center justify-center gap-x-10 gap-y-3 text-sm font-semibold text-ink/60 tracking-wide">
      <span>FAIR WORK COMPLIANT</span>
      <span class="text-ink/20">·</span>
      <span>STP LODGEMENT</span>
      <span class="text-ink/20">·</span>
      <span>BAS &amp; GST</span>
      <span class="text-ink/20">·</span>
      <span>XERO · MYOB · QUICKBOOKS</span>
    </div>
  </section>

  <!-- PROBLEM / DIFFERENTIATORS -->
  <section class="mx-auto max-w-6xl px-6 py-20 md:py-28">
    <div class="max-w-2xl">
      <h2 class="font-[General_Sans] font-bold text-3xl md:text-4xl tracking-tight">
        You didn't start a business to spend your days on admin.
      </h2>
      <p class="mt-4 text-slate text-lg leading-relaxed">
        Chasing invoices, wrangling rosters, keeping the books straight — it's
        necessary, but it's not the job. Hyture takes it off your plate.
      </p>
    </div>

    <div class="mt-14 grid sm:grid-cols-2 gap-x-10 gap-y-10">
      {differentiators.map((d) => (
        <div class="flex gap-4">
          <div class="w-2 shrink-0 rounded-full bg-teal"></div>
          <div>
            <h3 class="font-semibold text-lg">{d.title}</h3>
            <p class="mt-1.5 text-slate leading-relaxed">{d.body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- SERVICE AREAS -->
  <section class="bg-ink text-sand py-20 md:py-28">
    <div class="mx-auto max-w-6xl px-6">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div class="max-w-lg">
          <h2 class="font-[General_Sans] font-bold text-3xl md:text-4xl tracking-tight">
            Seven areas. One 2IC.
          </h2>
          <p class="mt-4 text-sand/70 text-lg leading-relaxed">
            Start with one function, or hand over the whole back office.
            Every area scales from a single defined task to a fractional
            leadership role.
          </p>
        </div>
        <a href="/services" class="inline-flex items-center gap-1.5 font-semibold text-teal hover:text-teal-dark transition-colors shrink-0">
          Explore every service
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8H13M13 8L9 4M13 8L9 12" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
        </a>
      </div>

      <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {serviceAreas.map((s) => (
          <a href={`/services#${s.id}`} class="group rounded-xl bg-sand/[0.06] border border-sand/10 p-6 hover:bg-sand/[0.1] hover:border-teal/40 transition-colors">
            <h3 class="font-semibold text-lg group-hover:text-teal transition-colors">{s.name}</h3>
            <p class="mt-2 text-sand/65 text-[0.95rem] leading-relaxed">{s.blurb}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TIER LADDER -->
  <section class="mx-auto max-w-6xl px-6 py-20 md:py-28">
    <div class="max-w-2xl">
      <h2 class="font-[General_Sans] font-bold text-3xl md:text-4xl tracking-tight">
        Start small. Grow into a full 2IC.
      </h2>
      <p class="mt-4 text-slate text-lg leading-relaxed">
        Every service area is structured the same way — three tiers, each one
        a genuine step up in scope, not just a bigger invoice.
      </p>
    </div>

    <div class="mt-14 grid md:grid-cols-3 gap-6">
      <div class="rounded-2xl border border-ink/10 p-7">
        <div class="h-1.5 w-10 rounded-full bg-teal/40 mb-5"></div>
        <span class="text-xs font-bold tracking-wide text-teal-dark">L1 — CORE</span>
        <h3 class="mt-2 font-[General_Sans] font-semibold text-xl">Single service, done reliably</h3>
        <p class="mt-3 text-slate leading-relaxed">Repetitive, well-defined tasks with clear procedures. Monthly subscription, cancel anytime, live within 5 business days.</p>
      </div>
      <div class="rounded-2xl border border-ink/10 p-7">
        <div class="h-1.5 w-16 rounded-full bg-teal/70 mb-5"></div>
        <span class="text-xs font-bold tracking-wide text-teal-dark">L2 — ADVANCED</span>
        <h3 class="mt-2 font-[General_Sans] font-semibold text-xl">Broader scope, real ownership</h3>
        <p class="mt-3 text-slate leading-relaxed">Reporting, insight, and process ownership layered on top of L1. Scoped in an onboarding consult, 3-month minimum.</p>
      </div>
      <div class="rounded-2xl border-2 border-teal p-7 bg-teal/5">
        <div class="h-1.5 w-24 rounded-full bg-teal mb-5"></div>
        <span class="text-xs font-bold tracking-wide text-teal-dark">L3 — STRATEGIC</span>
        <h3 class="mt-2 font-[General_Sans] font-semibold text-xl">Your fractional 2IC</h3>
        <p class="mt-3 text-slate leading-relaxed">No fixed procedure — we design the solution around your business. Bespoke retainer, 6-month minimum.</p>
      </div>
    </div>
  </section>

  <!-- AI + HUMAN -->
  <section class="bg-sand-dark/60 py-20 md:py-28">
    <div class="mx-auto max-w-6xl px-6 grid md:grid-cols-2 gap-14 items-start">
      <div>
        <h2 class="font-[General_Sans] font-bold text-3xl md:text-4xl tracking-tight">
          AI is the backbone. A person always signs off.
        </h2>
        <p class="mt-4 text-slate text-lg leading-relaxed">
          Not a chatbot bolted onto the side — AI is how we deliver faster and
          more accurately, at a lower cost than a traditional outsourcing model.
        </p>
        <ul class="mt-8 space-y-4">
          {[
            'No unreviewed communication sent in your business name',
            'No financial transaction processed without human sign-off',
            'No compliance lodgement submitted without qualified review',
            'A named account manager for every client',
          ].map((item) => (
            <li class="flex gap-3">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" class="shrink-0 mt-0.5">
                <circle cx="10" cy="10" r="9" stroke="#00C2B8" stroke-width="1.5"/>
                <path d="M6 10.2L8.6 12.8L14 7" stroke="#00C2B8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
              <span class="text-ink/85">{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="rounded-2xl bg-white border border-ink/10 p-8">
        <h3 class="font-semibold text-sm uppercase tracking-wide text-ink/50">What AI handles</h3>
        <div class="mt-5 space-y-4">
          {[
            ['Document capture & extraction', 'Invoices, receipts, contracts read and classified automatically'],
            ['Intelligent data entry', 'Structured data validated and cross-referenced, no manual typing'],
            ['Anomaly detection', 'Unusual transactions and compliance flags surfaced early'],
            ['Drafting & reporting', 'Emails, summaries and dashboards prepared for human review'],
          ].map(([title, body]) => (
            <div class="flex gap-4 pb-4 border-b border-ink/8 last:border-0 last:pb-0">
              <div class="w-1.5 rounded-full bg-amber shrink-0"></div>
              <div>
                <p class="font-semibold text-[0.95rem]">{title}</p>
                <p class="text-slate text-sm mt-0.5">{body}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="mx-auto max-w-6xl px-6 py-20 md:py-28">
    <div class="rounded-3xl bg-ink text-sand px-8 py-16 md:px-16 md:py-20 text-center">
      <h2 class="font-[General_Sans] font-bold text-3xl md:text-4xl tracking-tight max-w-2xl mx-auto">
        You build the business. We'll handle the complexity.
      </h2>
      <p class="mt-4 text-sand/70 text-lg max-w-xl mx-auto">
        Book a scoping call and we'll map out exactly which service areas make sense to start with.
      </p>
      <a href="/contact" class="mt-8 inline-flex items-center rounded-full bg-amber text-ink px-8 py-3.5 font-semibold hover:brightness-95 transition">
        Book a scoping call
      </a>
    </div>
  </section>
</Layout>
