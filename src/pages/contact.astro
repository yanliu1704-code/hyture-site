---
import Layout from '../layouts/Layout.astro';
import CalEmbed from '../components/CalEmbed.astro';

// Set this to your deployed contact-form worker URL after `wrangler deploy`
// in /worker-contact-form.
const CONTACT_WORKER_URL = "https://lzproxy-contact.YOUR-SUBDOMAIN.workers.dev";
---

<Layout title="Contact" description="Book a scoping call with LZproxy, or send us a message about which service area fits your business.">
  <section class="mx-auto max-w-4xl px-6 pt-16 pb-4 md:pt-20 text-center">
    <span class="inline-flex rounded-full bg-ink/5 border border-ink/10 px-3.5 py-1.5 text-xs font-semibold uppercase tracking-wide text-ink/70">
      Book a scoping call
    </span>
    <h1 class="mt-6 font-[General_Sans] font-bold text-4xl tracking-tight">
      Pick a time. We'll take it from there.
    </h1>
    <p class="mt-5 text-slate text-lg leading-relaxed max-w-xl mx-auto">
      A free, no-obligation 20-minute call — pick whatever slot works for you
      and you'll get an instant calendar invite.
    </p>
  </section>

  <section class="mx-auto max-w-3xl px-6 py-10">
    <CalEmbed />
  </section>

  <!-- GENERAL INQUIRY -->
  <section class="mx-auto max-w-3xl px-6 py-16 md:py-20 border-t border-ink/10">
    <div class="text-center mb-10">
      <span class="inline-flex rounded-full bg-ink/5 border border-ink/10 px-3.5 py-1.5 text-xs font-semibold uppercase tracking-wide text-ink/70">
        Not ready to book yet?
      </span>
      <h2 class="mt-5 font-[General_Sans] font-bold text-2xl md:text-3xl tracking-tight">
        Ask us a question instead.
      </h2>
      <p class="mt-3 text-slate">We reply within one business day.</p>
    </div>

    <form id="lzproxy-contact-form" class="rounded-2xl border border-ink/10 p-7 space-y-5" data-worker-url={CONTACT_WORKER_URL}>
      <div>
        <label for="name" class="block text-sm font-semibold mb-1.5">Name</label>
        <input id="name" name="name" type="text" required class="w-full rounded-lg border border-ink/15 px-3.5 py-2.5 text-sm focus:outline-none focus:border-teal" />
      </div>
      <div>
        <label for="business" class="block text-sm font-semibold mb-1.5">Business name</label>
        <input id="business" name="business" type="text" class="w-full rounded-lg border border-ink/15 px-3.5 py-2.5 text-sm focus:outline-none focus:border-teal" />
      </div>
      <div>
        <label for="email" class="block text-sm font-semibold mb-1.5">Email</label>
        <input id="email" name="email" type="email" required class="w-full rounded-lg border border-ink/15 px-3.5 py-2.5 text-sm focus:outline-none focus:border-teal" />
      </div>
      <div>
        <label for="area" class="block text-sm font-semibold mb-1.5">Area of interest</label>
        <select id="area" name="area" class="w-full rounded-lg border border-ink/15 px-3.5 py-2.5 text-sm focus:outline-none focus:border-teal bg-white">
          <option>Bookkeeping & Financial Management</option>
          <option>Administration & Executive Support</option>
          <option>HR & Payroll</option>
          <option>Operations & Procurement</option>
          <option>Marketing</option>
          <option>Customer Service</option>
          <option>Systems & Project Management</option>
          <option>Not sure yet</option>
        </select>
      </div>
      <div>
        <label for="message" class="block text-sm font-semibold mb-1.5">What's slowing you down right now?</label>
        <textarea id="message" name="message" rows="4" class="w-full rounded-lg border border-ink/15 px-3.5 py-2.5 text-sm focus:outline-none focus:border-teal"></textarea>
      </div>
      <button type="submit" id="lzproxy-contact-submit" class="w-full rounded-full bg-amber text-ink px-6 py-3 font-semibold hover:brightness-95 transition">
        Send message
      </button>
      <p id="lzproxy-contact-status" class="text-xs text-center min-h-[1rem]"></p>
    </form>
  </section>
</Layout>

<script>
  const form = document.getElementById('lzproxy-contact-form') as HTMLFormElement | null;
  const status = document.getElementById('lzproxy-contact-status');
  const submitBtn = document.getElementById('lzproxy-contact-submit') as HTMLButtonElement | null;
  const workerUrl = form?.dataset.workerUrl || '';

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!status || !submitBtn) return;

    if (!workerUrl || workerUrl.includes('YOUR-SUBDOMAIN')) {
      status.textContent = "This form isn't connected yet — set CONTACT_WORKER_URL once the worker is deployed.";
      status.className = 'text-xs text-center min-h-[1rem] text-amber';
      return;
    }

    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    submitBtn.disabled = true;
    submitBtn.textContent = 'Sending…';
    status.textContent = '';

    try {
      const res = await fetch(workerUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      if (!res.ok) throw new Error('Request failed');

      form.reset();
      status.textContent = "Thanks — we'll be in touch within one business day.";
      status.className = 'text-xs text-center min-h-[1rem] text-teal-dark font-semibold';
    } catch (err) {
      status.textContent = "Something went wrong sending that — please try again, or book a call above instead.";
      status.className = 'text-xs text-center min-h-[1rem] text-red-600';
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send message';
    }
  });
</script>
