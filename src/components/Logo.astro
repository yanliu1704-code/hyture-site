---
interface Props {
  variant?: 'default' | 'on-dark';
  class?: string;
  showWordmark?: boolean;
}
const { variant = 'default', class: className = '', showWordmark = true } = Astro.props;

const textColor = variant === 'on-dark' ? '#F5F2EA' : '#1B2A4A';
---

<a href="/" class={`inline-flex items-center gap-2.5 group ${className}`} aria-label="LZproxy home">
  {variant === 'on-dark' ? (
    <span class="inline-flex items-center justify-center rounded-lg bg-sand px-2 py-1.5 shrink-0">
      <img src="/lzproxy-logo-mark.png" alt="LZproxy" class="h-6 w-auto" />
    </span>
  ) : (
    <img src="/lzproxy-logo-mark.png" alt="LZproxy" class="h-8 w-auto shrink-0" />
  )}
  {showWordmark && (
    <span class="font-[General_Sans] font-bold text-[1.5rem] leading-none tracking-tight" style={`color:${textColor}`}>
      LZproxy
    </span>
  )}
</a>
