---
interface Props {
  variant?: 'gradient' | 'solid-light' | 'solid-dark';
  class?: string;
  showWordmark?: boolean;
}
const { variant = 'gradient', class: className = '', showWordmark = true } = Astro.props;

const strokeColor =
  variant === 'solid-dark' ? '#1B2A4A' : variant === 'solid-light' ? '#F5F2EA' : 'url(#hyture-ribbon-grad)';
const textColor = variant === 'solid-light' ? '#F5F2EA' : '#1B2A4A';
const tipColor = variant === 'solid-light' ? '#F5F2EA' : '#00C2B8';
---

<a href="/" class={`inline-flex items-center gap-2.5 group ${className}`} aria-label="Hyture home">
  <svg width="34" height="34" viewBox="0 0 260 260" fill="none" xmlns="http://www.w3.org/2000/svg" class="shrink-0">
    <defs>
      <linearGradient id="hyture-ribbon-grad" x1="0%" y1="100%" x2="100%" y2="0%">
        <stop offset="0%" stop-color="#1B2A4A" />
        <stop offset="100%" stop-color="#00C2B8" />
      </linearGradient>
    </defs>
    <path
      d="M 40 190 C 40 138, 40 96, 90 74 C 140 52, 140 108, 90 128 C 40 148, 40 88, 90 46 C 122 20, 165 20, 190 45"
      fill="none" stroke={strokeColor} stroke-width="26" stroke-linecap="round"
    ></path>
    <path d="M 190 45 L 206 28 M 190 45 L 200 62" stroke={tipColor} stroke-width="13" stroke-linecap="round" fill="none"></path>
  </svg>
  {showWordmark && (
    <span class="font-[General_Sans] font-bold text-[1.55rem] leading-none tracking-tight" style={`color:${textColor}`}>
      hyture
    </span>
  )}
</a>
