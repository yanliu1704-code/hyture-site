---
// Set this to your deployed Worker's URL after `wrangler deploy` in /worker.
// e.g. "https://lzproxy-chat.<your-subdomain>.workers.dev"
const CHAT_WORKER_URL = "https://lzproxy-chat.yanliu1704.workers.dev";
---
<div id="lzproxy-chat-root" class="fixed bottom-5 right-5 z-[60]" data-worker-url={CHAT_WORKER_URL}>
  <button
    id="lzproxy-chat-toggle"
    class="flex items-center gap-2.5 rounded-full bg-ink text-sand pl-4 pr-5 py-3.5 shadow-lg hover:bg-ink-light transition-colors"
    aria-expanded="false"
    aria-controls="lzproxy-chat-panel"
  >
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
      <path d="M2 10C2 5.58 5.58 2 10 2s8 3.58 8 8-3.58 8-8 8c-1.13 0-2.2-.23-3.18-.66L2 18l1.1-4.4C2.4 12.5 2 11.3 2 10Z" stroke="#00C2B8" stroke-width="1.5" stroke-linejoin="round"/>
    </svg>
    <span class="text-sm font-semibold">Ask LZproxy</span>
  </button>

  <div
    id="lzproxy-chat-panel"
    class="hidden absolute bottom-[64px] right-0 w-[340px] max-w-[88vw] rounded-2xl bg-white border border-ink/10 shadow-2xl overflow-hidden"
  >
    <div class="bg-ink text-sand px-5 py-4">
      <p class="font-semibold text-sm">LZproxy assistant</p>
      <p class="text-sand/60 text-xs mt-0.5">Usually replies in a couple of minutes</p>
    </div>
    <div id="lzproxy-chat-messages" class="h-[280px] overflow-y-auto px-4 py-4 space-y-3 text-sm">
      <div class="bg-sand-dark/60 rounded-xl rounded-tl-sm px-3.5 py-2.5 max-w-[85%] text-ink/85">
        Hi 👋 I'm the LZproxy assistant. Ask me about our services, pricing, or
        book a scoping call — what can I help with?
      </div>
    </div>
    <div id="lzproxy-chat-typing" class="hidden px-4 pb-2 text-xs text-slate">LZproxy assistant is typing…</div>
    <form id="lzproxy-chat-form" class="flex items-center gap-2 border-t border-ink/10 p-3">
      <input
        id="lzproxy-chat-input"
        type="text"
        placeholder="Type a message…"
        autocomplete="off"
        class="flex-1 rounded-full border border-ink/15 px-4 py-2 text-sm focus:outline-none focus:border-teal"
      />
      <button type="submit" class="w-9 h-9 shrink-0 rounded-full bg-teal flex items-center justify-center hover:bg-teal-dark transition-colors" aria-label="Send message">
        <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M1 7.5L14 1L9 14L6.5 8.5L1 7.5Z" stroke="#1B2A4A" stroke-width="1.3" stroke-linejoin="round"/></svg>
      </button>
    </form>
  </div>
</div>

<script>
  const root = document.getElementById('lzproxy-chat-root');
  const workerUrl = root?.dataset.workerUrl || '';

  const toggle = document.getElementById('lzproxy-chat-toggle');
  const panel = document.getElementById('lzproxy-chat-panel');
  const form = document.getElementById('lzproxy-chat-form') as HTMLFormElement | null;
  const input = document.getElementById('lzproxy-chat-input') as HTMLInputElement | null;
  const messages = document.getElementById('lzproxy-chat-messages');
  const typingIndicator = document.getElementById('lzproxy-chat-typing');

  // Keep a short rolling history in memory (not persisted) to send as context.
  const history: { role: 'user' | 'assistant'; content: string }[] = [];

  toggle?.addEventListener('click', () => {
    const isHidden = panel?.classList.contains('hidden');
    panel?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(isHidden));
    if (isHidden) input?.focus();
  });

  function addBubble(text: string, role: 'user' | 'assistant') {
    if (!messages) return;
    const bubble = document.createElement('div');
    bubble.className =
      role === 'user'
        ? 'bg-ink text-sand rounded-xl rounded-tr-sm px-3.5 py-2.5 max-w-[85%] ml-auto'
        : 'bg-sand-dark/60 rounded-xl rounded-tl-sm px-3.5 py-2.5 max-w-[85%] text-ink/85';
    bubble.textContent = text;
    messages.appendChild(bubble);
    messages.scrollTop = messages.scrollHeight;
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const text = input?.value.trim();
    if (!text || !messages) return;

    addBubble(text, 'user');
    if (input) input.value = '';

    if (!workerUrl || workerUrl.includes('YOUR-SUBDOMAIN')) {
      addBubble("This assistant isn't connected yet — set CHAT_WORKER_URL in ChatWidget.astro once the Worker is deployed. In the meantime, book a scoping call from the Contact page!", 'assistant');
      return;
    }

    typingIndicator?.classList.remove('hidden');
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    if (submitBtn) submitBtn.disabled = true;

    try {
      const res = await fetch(workerUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ message: text, history }),
      });

      const data = await res.json();
      const reply = data?.reply || "Sorry, I didn't catch that — could you try again?";

      history.push({ role: 'user', content: text });
      history.push({ role: 'assistant', content: reply });

      addBubble(reply, 'assistant');
    } catch (err) {
      addBubble("Sorry, something went wrong reaching the assistant. Please try again, or book a scoping call from the Contact page.", 'assistant');
    } finally {
      typingIndicator?.classList.add('hidden');
      if (submitBtn) submitBtn.disabled = false;
    }
  });
</script>
