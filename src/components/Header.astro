---
import Logo from './Logo.astro';

const navItems = [
  { label: 'Services', href: '/services' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'How it works', href: '/how-it-works' },
  { label: 'About', href: '/about' },
];
---

<header class="sticky top-0 z-50 bg-sand/90 backdrop-blur-sm border-b border-ink/10">
  <div class="mx-auto max-w-6xl px-6 flex items-center justify-between h-[72px]">
    <Logo />

    <nav class="hidden md:flex items-center gap-8">
      {navItems.map((item) => (
        <a
          href={item.href}
          class="text-[0.95rem] font-medium text-ink/80 hover:text-ink transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-3">
      <a
        href="/contact"
        class="hidden sm:inline-flex items-center rounded-full bg-ink text-sand px-5 py-2.5 text-sm font-semibold hover:bg-ink-light transition-colors"
      >
        Book a scoping call
      </a>
      <button
        id="mobile-nav-toggle"
        class="md:hidden inline-flex items-center justify-center w-10 h-10 rounded-full border border-ink/20"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg width="18" height="14" viewBox="0 0 18 14" fill="none">
          <path d="M0 1H18M0 7H18M0 13H18" stroke="#1B2A4A" stroke-width="1.6" />
        </svg>
      </button>
    </div>
  </div>

  <nav id="mobile-nav" class="md:hidden hidden border-t border-ink/10 bg-sand">
    <div class="mx-auto max-w-6xl px-6 py-4 flex flex-col gap-4">
      {navItems.map((item) => (
        <a href={item.href} class="text-ink font-medium">{item.label}</a>
      ))}
      <a href="/contact" class="inline-flex items-center rounded-full bg-ink text-sand px-5 py-2.5 text-sm font-semibold w-fit">
        Book a scoping call
      </a>
    </div>
  </nav>
</header>

<script>
  const toggle = document.getElementById('mobile-nav-toggle');
  const nav = document.getElementById('mobile-nav');
  toggle?.addEventListener('click', () => {
    const isHidden = nav?.classList.contains('hidden');
    nav?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(isHidden));
  });
</script>
