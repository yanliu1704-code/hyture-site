---
// After creating your event type at cal.com, replace this with
// "your-username/your-event-slug" (find it in the event type's URL).
const CAL_LINK = "sammi-liu-5ti03s/scoping-call";
---

<div id="lzproxy-cal-embed" class="w-full min-h-[650px] rounded-2xl overflow-hidden border border-ink/10 bg-white"></div>

<script define:vars={{ CAL_LINK }}>
  (function (C, A, L) {
    let p = function (a, ar) { a.q.push(ar); };
    let d = C.document;
    C.Cal = C.Cal || function () {
      let cal = C.Cal;
      let ar = arguments;
      if (!cal.loaded) {
        cal.ns = {};
        cal.q = cal.q || [];
        d.head.appendChild(d.createElement("script")).src = A;
        cal.loaded = true;
      }
      if (ar[0] === L) {
        const api = function () { p(api, arguments); };
        const namespace = ar[1];
        api.q = api.q || [];
        if (typeof namespace === "string") {
          cal.ns[namespace] = cal.ns[namespace] || api;
          p(cal.ns[namespace], ar);
          p(cal, ["initNamespace", namespace]);
        } else p(cal, ar);
        return;
      }
      p(cal, ar);
    };
  })(window, "https://app.cal.com/embed/embed.js", "init");

  if (!CAL_LINK.startsWith("YOUR-CAL-USERNAME")) {
    Cal("init", { origin: "https://cal.com" });
    Cal("inline", {
      elementOrSelector: "#lzproxy-cal-embed",
      calLink: CAL_LINK,
      config: {
        theme: "light",
        layout: "month_view",
      },
    });
    Cal("ui", {
      styles: { branding: { brandColor: "#00C2B8" } },
      hideEventTypeDetails: false,
    });
  } else {
    document.getElementById("lzproxy-cal-embed").innerHTML =
      '<div style="padding:2.5rem;text-align:center;color:#4A5570;font-size:0.95rem;">Booking calendar not connected yet — set CAL_LINK in CalEmbed.astro once your Cal.com event type is live.</div>';
  }
</script>
