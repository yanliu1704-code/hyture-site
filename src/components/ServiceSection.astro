---
interface Tier {
  label: string;
  items: string[];
  engagement: string;
}
interface Props {
  id: string;
  number: string;
  name: string;
  intro: string;
  tiers: [Tier, Tier, Tier];
  showHeader?: boolean;
}
const { id, number, name, intro, tiers, showHeader = true } = Astro.props;
const tierStyles = [
  { badge: 'text-teal-dark', barWidth: 'w-10', barOpacity: 'bg-teal/40', border: 'border-ink/10' },
  { badge: 'text-teal-dark', barWidth: 'w-16', barOpacity: 'bg-teal/70', border: 'border-ink/10' },
  { badge: 'text-teal-dark', barWidth: 'w-24', barOpacity: 'bg-teal', border: 'border-2 border-teal bg-teal/5' },
];
---

<div id={id} class="scroll-mt-24 py-16 md:py-20 border-b border-ink/10 last:border-0">
  {showHeader && (
    <>
      <div class="flex items-baseline gap-4">
        <span class="font-[General_Sans] text-sand-dark text-3xl font-bold text-ink/15">{number}</span>
        <h2 class="font-[General_Sans] font-bold text-2xl md:text-3xl tracking-tight">{name}</h2>
      </div>
      <p class="mt-3 text-slate text-lg leading-relaxed max-w-2xl">{intro}</p>
    </>
  )}

  <div class="mt-8 grid md:grid-cols-3 gap-5">
    {tiers.map((tier, i) => (
      <div class={`rounded-2xl p-6 ${tierStyles[i].border}`}>
        <div class={`h-1.5 ${tierStyles[i].barWidth} rounded-full ${tierStyles[i].barOpacity} mb-4`}></div>
        <span class={`text-xs font-bold tracking-wide ${tierStyles[i].badge}`}>{tier.label}</span>
        <ul class="mt-3 space-y-2">
          {tier.items.map((item) => (
            <li class="text-[0.9rem] text-ink/80 leading-snug flex gap-2">
              <span class="text-teal shrink-0">–</span>
              <span>{item}</span>
            </li>
          ))}
        </ul>
        <p class="mt-4 pt-4 border-t border-ink/10 text-xs text-slate">{tier.engagement}</p>
      </div>
    ))}
  </div>
</div>
